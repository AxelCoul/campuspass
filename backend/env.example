# Copier ces variables dans Render (Web Service campuspass-API) > Environment.
# Ne pas committer de valeurs réelles.

# Obligatoire en production (changer le défaut local)
JWT_SECRET=

# Base (souvent injectée par Render si PostgreSQL liée, ou DATABASE_URL manuelle)
# DATABASE_URL=postgresql://...

# CORS : origines du front admin (localhost + URL Vercel une fois déployé)
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:4300,http://127.0.0.1:4300

# Yengapay
YENGAPAY_API_KEY=
YENGAPAY_SITE_ID=
YENGAPAY_GROUP_ID=
YENGAPAY_PROJECT_ID=
YENGAPAY_PAYLINK_URL=
# URLs publiques Render, ex. https://campuspass-api-xxxx.onrender.com/api/subscription/yengapay/webhook
YENGAPAY_NOTIFY_URL=
YENGAPAY_RETURN_URL=
